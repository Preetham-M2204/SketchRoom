# Optional: set this to your LAN URL when sharing room links to other devices on the same network.
# Example: VITE_SHARE_BASE_URL=http://192.168.1.12:5173
VITE_SHARE_BASE_URL=

# Backend API target used by Vite dev proxy.
# Keep this as HTTP backend unless you also run backend with HTTPS.
VITE_BACKEND_TARGET=http://localhost:5000

# Set to true to run Vite over HTTPS for browser mic/screen-share APIs.
# Note: for same-network devices, use trusted cert paths below for best results.
VITE_DEV_HTTPS=false

# Preferred trusted certificate files for intranet mic/screen-share (mkcert).
# Paths can be absolute or relative to frontend/.
# Example (mkcert):
# VITE_HTTPS_CERT_PATH=./certs/sketchroom-lan.pem
# VITE_HTTPS_KEY_PATH=./certs/sketchroom-lan-key.pem
VITE_HTTPS_CERT_PATH=
VITE_HTTPS_KEY_PATH=

